<%# The detail view IS a machine. Uses:
    mn-ctx, mn-state, <mn-temporal>(animate)</mn-temporal>, <mn-text>, <mn-class> with cond,
    mn-each + mn-key for items/effects/history, <mn-show>,
    <mn-bind attr="data-item">, <mn-on event="click.outside"> for delete confirmation,
    (date-fmt), (str), (count), (cond), (let), (fn), (->>),
    (filter), (map), (reduce), (sort-by) %>

<div class="max-w-2xl mx-auto space-y-4">
  <button mn-to="orders" class="btn btn-ghost btn-sm gap-1">
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg> Back
  </button>

  <div mn="order-detail" mn-ctx='<%- JSON.stringify(order).replace(/'/g, "&#39;") %>'>
    <div mn-state="viewing">
      <mn-temporal>(animate)</mn-temporal>

      <!-- Header -->
      <div class="card bg-base-100 shadow-xl mb-4">
        <div class="card-body p-5 gap-3">
          <div class="flex items-start justify-between">
            <div>
              <h2 class="text-2xl font-bold"><mn-text>title</mn-text></h2>
              <p class="text-sm text-base-content/50 mt-1">
                <mn-text>(->> created_at (date-fmt) (str 'Created '))</mn-text>
              </p>
            </div>
            <div class="text-right">
              <p class="text-3xl font-bold font-mono"><mn-text>(str '£' amount)</mn-text></p>
              <div class="badge mt-1">
                <mn-text>status</mn-text>
                <mn-class>(cond
                  (= status 'fulfilled') 'badge-success'
                  (= status 'rejected') 'badge-error'
                  (= status 'approved') 'badge-info'
                  true 'badge-ghost')</mn-class>
              </div>
            </div>
          </div>
          <div>
            <mn-show>(not (empty? notes))</mn-show>
            <h4 class="text-xs font-bold uppercase tracking-wider text-base-content/40 mb-1">Notes</h4>
            <p class="text-sm text-base-content/70"><mn-text>notes</mn-text></p>
          </div>
          <!-- Summary using let + ->> + reduce -->
          <p class="text-xs text-base-content/40">
            <mn-text>(let [total-qty (->> items (map (fn [i] (get i :qty))) (reduce + 0))]
                       (str (count items) ' items &middot; ' total-qty ' units &middot; £' amount))</mn-text>
          </p>
        </div>
      </div>

      <!-- Items — mn-each with mn-key -->
      <div class="card bg-base-100 shadow-xl mb-4">
        <div class="card-body p-4 gap-2">
          <h3 class="text-xs font-bold uppercase tracking-wider text-base-content/40">
            <mn-text>(str 'Items (' (count items) ')')</mn-text>
          </h3>
          <template mn-each="items" mn-key="name">
            <div class="flex items-center justify-between bg-base-200 rounded px-3 py-2">
              <mn-bind attr="data-item">name</mn-bind>
              <span class="text-sm font-medium"><mn-text>name</mn-text></span>
              <span class="text-sm font-mono text-base-content/50"><mn-text>(str 'qty: ' qty)</mn-text></span>
            </div>
          </template>
        </div>
      </div>

      <!-- Effects — mn-each with sort-by and cond classes -->
      <div class="card bg-base-100 shadow-xl mb-4">
        <mn-show>(> (count effects) 0)</mn-show>
        <div class="card-body p-4 gap-2">
          <h3 class="text-xs font-bold uppercase tracking-wider text-base-content/40">Pipeline effects</h3>
          <template mn-key="detail"><mn-each>(->> effects (sort-by (fn [e] (get e :service))))</mn-each>
            <div class="flex items-center gap-2 text-xs bg-base-200 rounded px-3 py-2">
              <span class="badge badge-xs">
                <mn-text>type</mn-text>
                <mn-class>(cond (= type 'log') 'badge-info' (= type 'notify') 'badge-warning' (= type 'fulfil') 'badge-success' (= type 'persist') 'badge-accent' true 'badge-ghost')</mn-class>
              </span>
              <span class="badge badge-xs badge-outline"><mn-text>service</mn-text></span>
              <span class="text-base-content/60 font-mono"><mn-text>detail</mn-text></span>
            </div>
          </template>
          <!-- Effect count using filter -->
          <p class="text-xs text-base-content/30 mt-1">
            <mn-text>(let [logs (->> effects (filter (fn [e] (= (get e :type) 'log'))) (count))
                           notifs (->> effects (filter (fn [e] (= (get e :type) 'notify'))) (count))]
                      (str logs ' log &middot; ' notifs ' notify &middot; ' (count effects) ' total'))</mn-text>
          </p>
        </div>
      </div>

      <!-- History — mn-each -->
      <div class="card bg-base-100 shadow-xl mb-4">
        <mn-show>(> (count history) 0)</mn-show>
        <div class="card-body p-4 gap-2">
          <h3 class="text-xs font-bold uppercase tracking-wider text-base-content/40">Audit trail</h3>
          <template mn-each="history" mn-key="timestamp">
            <div class="flex items-center gap-2 text-xs bg-base-200 rounded px-3 py-2">
              <span class="badge badge-xs">
                <mn-text>event</mn-text>
                <mn-class>(cond (= event 'submitted') 'badge-info' (= event 'approved') 'badge-success' (= event 'rejected') 'badge-error' (= event 'fulfilled') 'badge-accent' true 'badge-ghost')</mn-class>
              </span>
              <span class="text-base-content/60 font-mono"><mn-text>(str from ' &rarr; ' to)</mn-text></span>
            </div>
          </template>
        </div>
      </div>

      <!-- Delete with click.outside confirmation -->
      <div class="flex justify-end">
        <div mn="delete-confirm" mn-ctx='{"open":false}'>
          <div mn-state="closed">
            <button mn-to="open" class="btn btn-error btn-sm btn-outline">Delete Order</button>
          </div>
          <div mn-state="open">
            <mn-temporal>(animate)</mn-temporal>
            <mn-on event="click.outside">(to closed)</mn-on>
            <mn-transition event="confirm-delete" to="closed">
              <mn-action>(emit delete-order (obj :id id))</mn-action>
            </mn-transition>
            <div class="flex items-center gap-2 bg-error/10 border border-error rounded-lg px-4 py-2">
              <span class="text-sm text-error">Are you sure?</span>
              <button mn-to="confirm-delete"
                      class="btn btn-error btn-xs">Yes, delete</button>
              <button mn-to="closed" class="btn btn-ghost btn-xs">Cancel</button>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
