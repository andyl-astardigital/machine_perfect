<%# Uses the order-card mn-define template (loaded via mn-import).
    mn-ctx on the machine element so bindings resolve correctly.
    Navigation uses (emit) in mn-on handlers to cross the nested machine boundary. %>
<div mn="order-card" mn-ctx='<%- JSON.stringify(order).replace(/'/g, "&#39;") %>'>
  <div slot="actions" class="flex gap-1 mt-1">
    <button class="btn btn-ghost btn-xs flex-1">
      <mn-on event="click">(emit navigate-detail (obj :id id))</mn-on>
      View
    </button>
    <button class="btn btn-ghost btn-xs text-error flex-1">
      <mn-on event="click">(emit delete-order (obj :id id))</mn-on>
      Delete
    </button>
  </div>
</div>
