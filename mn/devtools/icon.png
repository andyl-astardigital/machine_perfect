<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="512" height="512">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#4c1d95"/>
      <stop offset="100%" stop-color="#6d28d9"/>
    </linearGradient>
    <linearGradient id="gold" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#fbbf24"/>
      <stop offset="100%" stop-color="#f59e0b"/>
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect x="16" y="16" width="480" height="480" rx="80" fill="url(#bg)"/>

  <!-- ( — left paren / left transition arc -->
  <path
    d="M 224 76 C 58 166, 58 346, 224 436"
    fill="none"
    stroke="#e9d5ff"
    stroke-width="30"
    stroke-linecap="round"
  />

  <!-- ) — right paren / right transition arc -->
  <path
    d="M 288 76 C 454 166, 454 346, 288 436"
    fill="none"
    stroke="#e9d5ff"
    stroke-width="30"
    stroke-linecap="round"
  />

  <!-- State A — active (gold, filled) -->
  <circle cx="190" cy="256" r="52" fill="url(#gold)"/>

  <!-- State B — inactive (lavender, outlined) -->
  <circle cx="322" cy="256" r="52" fill="none" stroke="#e9d5ff" stroke-width="10"/>
</svg>
