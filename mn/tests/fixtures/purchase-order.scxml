<scxml xmlns="http://www.w3.org/2005/07/scxml"

       initial="draft">

  <datamodel>
    <data id="title" expr="'Untitled'"/>
    <data id="items" expr="[]"/>
    <data id="amount" expr="0"/>
    <data id="submitted_at" expr="nil"/>
    <data id="approved_at" expr="nil"/>
    <data id="rejected_reason" expr="nil"/>
  </datamodel>

  <state id="draft">
    <transition event="submit" target="submitted">
      <mn-guard>(and (> (count items) 0) (> amount 0))</mn-guard>
      <mn-action>(set! submitted_at (now))</mn-action>
    </transition>
  </state>

  <state id="submitted">
    <transition event="approve" target="approved">
      <mn-action>(set! approved_at (now))</mn-action>
      <mn-emit>order-approved</mn-emit>
    </transition>
    <transition event="reject" target="rejected">
      <mn-action>(set! rejected_reason (get $event :reason))</mn-action>
    </transition>
    <transition event="withdraw" target="draft"/>
  </state>

  <final id="approved"/>
  <final id="rejected"/>

</scxml>
