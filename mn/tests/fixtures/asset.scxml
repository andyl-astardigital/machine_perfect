<scxml xmlns="http://www.w3.org/2005/07/scxml"

       initial="procurement">

  <datamodel>
    <data id="asset_tag" expr="nil"/>
    <data id="location" expr="nil"/>
    <data id="commissioned_at" expr="nil"/>
    <data id="decommissioned_at" expr="nil"/>
  </datamodel>

  <state id="procurement">
    <transition event="receive" target="received">
      <mn-action>(set! asset_tag (str 'AST-' (now)))</mn-action>
    </transition>
  </state>

  <state id="received">
    <transition event="commission" target="in-service">
      <mn-action>(set! commissioned_at (now))</mn-action>
    </transition>
    <transition event="reject-delivery" target="returned"/>
  </state>

  <state id="in-service">
    <transition event="decommission" target="decommissioned">
      <mn-action>(set! decommissioned_at (now))</mn-action>
    </transition>
    <transition event="repair" target="maintenance"/>
    <transition event="transfer" target="transferring">
      <mn-action>(set! location (get $event :location))</mn-action>
    </transition>
  </state>

  <state id="transferring">
    <transition event="arrive" target="in-service"/>
  </state>

  <state id="maintenance">
    <transition event="return-to-service" target="in-service"/>
    <transition event="write-off" target="disposed"/>
  </state>

  <final id="decommissioned"/>
  <final id="disposed"/>
  <final id="returned"/>

</scxml>
