{
  "name": "machine-native",
  "version": "0.5.0",
  "description": "Application platform where state machines are the unit of definition, execution, and exchange. S-expressions for logic. Markup as substrate.",
  "main": "mn/engine.js",
  "browser": "mn/browser.js",
  "exports": {
    ".": "./mn/engine.js",
    "./engine": "./mn/engine.js",
    "./machine": "./mn/machine.js",
    "./browser": "./mn/browser.js",
    "./scxml": "./mn/scxml.js",
    "./transforms": "./mn/transforms.js",
    "./host": "./mn/host.js",
    "./registry": "./mn/registry.js",
    "./adapters": "./mn/adapters.js"
  },
  "files": [
    "mn/engine.js",
    "mn/machine.js",
    "mn/transforms.js",
    "mn/browser.js",
    "mn/scxml.js",
    "mn/adapters.js",
    "mn/host.js",
    "mn/registry.js",
    "LICENSE",
    "README.md",
    "REFERENCE.md"
  ],
  "scripts": {
    "dev": "npx serve .",
    "test": "node mn/tests/engine.test.js && node mn/tests/machine.test.js && node mn/tests/transforms.test.js && node mn/tests/scxml.test.js && node mn/tests/host.test.js && node mn/tests/adapters.test.js && node mn/tests/registry.test.js",
    "start": "node mn/host.js"
  },
  "keywords": [
    "state-machine",
    "fsm",
    "ui",
    "framework",
    "html",
    "declarative",
    "s-expressions",
    "components",
    "no-build",
    "reactive",
    "dependency-tracking"
  ],
  "author": "Andrew Lewis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andyl-astardigital/machine_native.git"
  },
  "bugs": {
    "url": "https://github.com/andyl-astardigital/machine_native/issues"
  },
  "homepage": "https://github.com/andyl-astardigital/machine_native",
  "devDependencies": {
    "ejs": "^5.0.1",
    "puppeteer": "^24.40.0"
  }
}
