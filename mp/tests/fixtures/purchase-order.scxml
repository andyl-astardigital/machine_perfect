<scxml xmlns="http://www.w3.org/2005/07/scxml"

       initial="draft">

  <datamodel>
    <data id="title" expr="'Untitled'"/>
    <data id="items" expr="[]"/>
    <data id="amount" expr="0"/>
    <data id="submitted_at" expr="nil"/>
    <data id="approved_at" expr="nil"/>
    <data id="rejected_reason" expr="nil"/>
  </datamodel>

  <state id="draft">
    <transition event="submit" target="submitted">
      <mp-guard>(and (> (count items) 0) (> amount 0))</mp-guard>
      <mp-action>(set! submitted_at (now))</mp-action>
    </transition>
  </state>

  <state id="submitted">
    <transition event="approve" target="approved">
      <mp-action>(set! approved_at (now))</mp-action>
      <mp-emit>order-approved</mp-emit>
    </transition>
    <transition event="reject" target="rejected">
      <mp-action>(set! rejected_reason (get $event :reason))</mp-action>
    </transition>
    <transition event="withdraw" target="draft"/>
  </state>

  <final id="approved"/>
  <final id="rejected"/>

</scxml>
